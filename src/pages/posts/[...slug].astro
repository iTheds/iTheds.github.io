---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter((entry) => !entry.data.draft);
  return posts.map((post) => ({
    params: { slug: post.data.slug || post.id.replace(/\.md$/, "") },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---
<BaseLayout title={post.data.title || post.id}>
  <article class="post-shell">
    <header class="post-header">
      <h1>{post.data.title || post.id}</h1>
      {post.data.subtitle && <p class="lede">{post.data.subtitle}</p>}
      <div class="meta-row">
        {post.data.date && <span>{post.data.date.toISOString().slice(0, 10)}</span>}
        {post.data.section && <span>{post.data.section}</span>}
        {post.data.sourcePath && <span>{post.data.sourcePath}</span>}
      </div>
      {(post.data.tags || []).length > 0 && (
        <div class="tag-row">
          {(post.data.tags || []).map((tag) => (
            <a class="tag" href={`/tags/${encodeURIComponent(tag)}`}>#{tag}</a>
          ))}
        </div>
      )}
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>
