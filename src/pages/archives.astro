---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = (await getCollection("blog"))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => {
    const left = a.data.date ? a.data.date.getTime() : 0;
    const right = b.data.date ? b.data.date.getTime() : 0;
    return right - left;
  });

const groups = new Map();
const getPostPath = (post) => post.data.slug || post.id.replace(/\.md$/, "");

for (const post of posts) {
  const year = String(post.data.date?.getFullYear() || "Unknown");
  if (!groups.has(year)) {
    groups.set(year, []);
  }
  groups.get(year).push(post);
}
---
<BaseLayout title="Archives">
  <section class="page-shell">
    <h1>Archives</h1>
    {[...groups.entries()].map(([year, entries]) => (
      <section class="section">
        <h2>{year}</h2>
        <ul class="list-reset">
          {entries.map((post) => (
            <li>
              <a href={`/posts/${getPostPath(post)}/`}>{post.data.title || getPostPath(post)}</a>
              {" · "}
              {post.data.date?.toISOString().slice(0, 10)}
            </li>
          ))}
        </ul>
      </section>
    ))}
  </section>
</BaseLayout>
